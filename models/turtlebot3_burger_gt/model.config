<?xml version="1.0"?>
<model>
  <name>turtlebot3_burger_gt</name>
  <version>1.0</version>
  <sdf version="1.5">model.sdf</sdf>
  <author>
    <name>loc_eval</name>
  </author>
  <description>
    TurtleBot3 Burger with a ground-truth P3D plugin publishing /ground_truth/odom.
    Used for localization accuracy evaluation. Sensors/kinematics identical to the
    stock turtlebot3_burger model; only the ground-truth pose plugin is added.
  </description>
</model>
